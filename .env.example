ACEND_RPC_URL=https://api.mainnet-beta.solana.com
ACEND_CLUSTER=mainnet-beta
ACEND_PAIRS_CONFIG=config/pairs.mainnet.toml
ACEND_BIDS_CONFIG=config/standing-bids.deploy.json
ACEND_MFI_ENV=production

# Required on Railway — reject requests without this key
# ACEND_API_KEY=generate-a-long-random-string

# Only your Vercel app origin(s), comma-separated
# ACEND_CORS_ORIGINS=https://your-app.vercel.app,https://www.yourdomain.com

# Demo UI at / — keep false/offline in production (auto-off when API key set)
# ACEND_PUBLIC_UI=false

# Local only — Railway sets PORT
# ACEND_BIND=127.0.0.1:8080
